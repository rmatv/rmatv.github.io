&lt;td style=&#34;text-align:left&#34;&gt;больше 60&lt;/td&gt;
&lt;td style=&#34;text-align:right&#34;&gt;23&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td style=&#34;text-align:left&#34;&gt;75–175&lt;/td&gt;
